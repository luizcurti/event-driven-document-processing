{
  "info": {
    "_postman_id": "0f5de8f5-255b-4e24-a3f8-6f2f52be08f1",
    "name": "Document Processing Platform - LocalStack",
    "description": "Postman collection for local-only testing with LocalStack Community. This collection does not use API Gateway because local mode keeps API Gateway disabled. Instead, it invokes the Lambda functions directly through the LocalStack Lambda API and then uploads the sample PDF to the returned presigned S3 URL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('requestId')) {",
          "  pm.collectionVariables.set('requestId', 'req-local-' + pm.variables.replaceIn('{{$guid}}'));",
          "}",
          "if (!pm.collectionVariables.get('idempotencyKey')) {",
          "  pm.collectionVariables.set('idempotencyKey', pm.collectionVariables.get('requestId'));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Invoke Upload Lambda",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"version\": \"2.0\",\n  \"routeKey\": \"POST /documents\",\n  \"rawPath\": \"/documents\",\n  \"rawQueryString\": \"\",\n  \"headers\": {\n    \"content-type\": \"application/json\",\n    \"x-idempotency-key\": \"{{idempotencyKey}}\"\n  },\n  \"requestContext\": {\n    \"requestId\": \"{{requestId}}\",\n    \"http\": {\n      \"method\": \"POST\",\n      \"path\": \"/documents\"\n    }\n  },\n  \"isBase64Encoded\": false,\n  \"body\": \"{\\\"fileName\\\":\\\"{{sampleFileName}}\\\",\\\"contentType\\\":\\\"{{contentType}}\\\"}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{localstackEndpoint}}/2015-03-31/functions/{{uploadFunctionName}}/invocations",
          "protocol": "{{localstackProtocol}}",
          "host": [
            "{{localstackHost}}"
          ],
          "port": "{{localstackPort}}",
          "path": [
            "2015-03-31",
            "functions",
            "{{uploadFunctionName}}",
            "invocations"
          ]
        },
        "description": "Invokes the upload Lambda directly in LocalStack using the same API Gateway event contract expected by the handler."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const lambdaResponse = pm.response.json();",
              "pm.test('Upload lambda returns HTTP 200', function () {",
              "  pm.expect(lambdaResponse.statusCode).to.eql(200);",
              "});",
              "",
              "const body = JSON.parse(lambdaResponse.body);",
              "pm.collectionVariables.set('documentId', body.documentId);",
              "pm.collectionVariables.set('uploadUrl', body.uploadUrl);",
              "pm.collectionVariables.set('uploadKey', body.key);",
              "pm.collectionVariables.unset('requestId');",
              "pm.collectionVariables.unset('idempotencyKey');",
              "",
              "pm.test('Upload response contains required fields', function () {",
              "  pm.expect(body.documentId).to.be.a('string').and.not.empty;",
              "  pm.expect(body.uploadUrl).to.be.a('string').and.not.empty;",
              "  pm.expect(body.key).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "2. Upload PDF To Presigned URL",
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "{{contentType}}"
          }
        ],
        "body": {
          "mode": "file",
          "file": {
            "src": "{{localPdfPath}}"
          }
        },
        "url": {
          "raw": "{{uploadUrl}}"
        },
        "description": "Uploads the sample PDF from the postman folder to the presigned S3 URL returned by the upload Lambda."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Presigned upload succeeds', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "3. Invoke OCR Lambda",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"documentId\": \"{{documentId}}\",\n  \"bucket\": \"{{documentsBucket}}\",\n  \"key\": \"{{uploadKey}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{localstackEndpoint}}/2015-03-31/functions/{{ocrFunctionName}}/invocations",
          "protocol": "{{localstackProtocol}}",
          "host": [
            "{{localstackHost}}"
          ],
          "port": "{{localstackPort}}",
          "path": [
            "2015-03-31",
            "functions",
            "{{ocrFunctionName}}",
            "invocations"
          ]
        },
        "description": "Runs the local OCR Lambda mock and stores its JSON result as a collection variable for the merge step."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "pm.collectionVariables.set('ocrResult', JSON.stringify(body));",
              "pm.test('OCR response has expected shape', function () {",
              "  pm.expect(body).to.be.an('object');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },

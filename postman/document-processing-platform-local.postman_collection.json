            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "pm.collectionVariables.set('validationResult', JSON.stringify(body));",
              "pm.test('Validation response has expected shape', function () {",
              "  pm.expect(body).to.be.an('object');",
              "});"
            ]
          }
        }
      ],
      "response": []

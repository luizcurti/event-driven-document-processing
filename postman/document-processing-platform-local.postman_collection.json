          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{localstackEndpoint}}/2015-03-31/functions/{{metadataFunctionName}}/invocations",
          "protocol": "{{localstackProtocol}}",
          "host": [
            "{{localstackHost}}"
          ],
          "port": "{{localstackPort}}",
          "path": [
            "2015-03-31",
            "functions",
            "{{metadataFunctionName}}",
            "invocations"
          ]
        },
        "description": "Persists the merged processing result in DynamoDB and publishes the notification event to SQS."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "pm.test('Metadata lambda returns ok=true', function () {",
              "  pm.expect(body.ok).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "8. Invoke Get Document Status Lambda",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"version\": \"2.0\",\n  \"routeKey\": \"GET /documents/{documentId}\",\n  \"rawPath\": \"/documents/{{documentId}}\",\n  \"pathParameters\": {\n    \"documentId\": \"{{documentId}}\"\n  },\n  \"requestContext\": {\n    \"requestId\": \"status-{{documentId}}\",\n    \"http\": {\n      \"method\": \"GET\",\n      \"path\": \"/documents/{{documentId}}\"\n    }\n  },\n  \"isBase64Encoded\": false\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{localstackEndpoint}}/2015-03-31/functions/{{getDocumentFunctionName}}/invocations",
          "protocol": "{{localstackProtocol}}",
          "host": [
            "{{localstackHost}}"
          ],
          "port": "{{localstackPort}}",
          "path": [
            "2015-03-31",
            "functions",
            "{{getDocumentFunctionName}}",
            "invocations"
          ]
        },
        "description": "Fetches the final document status by invoking the status Lambda directly with an API Gateway-like event payload."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const lambdaResponse = pm.response.json();",
              "pm.test('Status lambda returns HTTP 200', function () {",
              "  pm.expect(lambdaResponse.statusCode).to.eql(200);",
              "});",
              "",
              "const body = JSON.parse(lambdaResponse.body);",
              "pm.test('Status response contains documentId and status', function () {",
              "  pm.expect(body.documentId).to.eql(pm.collectionVariables.get('documentId'));",
              "  pm.expect(body.status).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "response": []

    {
      "name": "6. Invoke Merge Results Lambda",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"documentId\": \"{{documentId}}\",\n  \"ocr\": {{ocrResult}},\n  \"thumbnail\": {{thumbnailResult}},\n  \"validation\": {{validationResult}}\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{localstackEndpoint}}/2015-03-31/functions/{{mergeResultsFunctionName}}/invocations",
          "protocol": "{{localstackProtocol}}",
          "host": [
            "{{localstackHost}}"
          ],
          "port": "{{localstackPort}}",
          "path": [
            "2015-03-31",
            "functions",
            "{{mergeResultsFunctionName}}",
            "invocations"
          ]
        },
        "description": "Combines OCR, thumbnail, and validation outputs using the same payload contract used in the local integration test."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "pm.collectionVariables.set('mergeResult', JSON.stringify(body));",
              "pm.test('Merge result contains documentId', function () {",
              "  pm.expect(body.documentId).to.eql(pm.collectionVariables.get('documentId'));",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "7. Invoke Metadata Lambda",
      "request": {
        "method": "POST",
        "header": [
